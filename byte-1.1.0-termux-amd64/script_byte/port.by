import("portscanner")

print(portscanner.banner())
print()
Domaim_to_ip = portscanner.resolve("github.com")
print()
port = portscanner.service(80)

print(Domaim_to_ip)
print()
print(port)
print()

scanner = portscanner.isopen(Domaim_to_ip, 22)
print(scanner)
print()

local ports = portscanner.scan(Domaim_to_ip, 1, 100)

for i, p in ipairs(ports) do
    print(
        p.port,
        p.service,
        p.state
    )
end
